<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Not found</title>
  <style>
    body {
      margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center;
      font-family: system-ui, -apple-system, sans-serif; background:#fafafa; color:#1a1a1a;
    }
    .wrap { text-align:center; padding: 24px; }
    h1 { font-size: 72px; margin: 0 0 8px; color:#630812; }
    p  { color:#555; margin: 0 0 20px; }
    a  { color:#630812; font-weight:600; text-decoration:none; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>404</h1>
    <p><%= it.message || 'This page was not found.' %></p>
    <p><a href="/">← Back home</a></p>
    <p style="font-size:12px; color:#aaa; margin-top:40px;">
      Powered by <a href="https://<%= it.rootDomain %>">Macaroonie</a>
    </p>
  </div>
</body>
</html>
