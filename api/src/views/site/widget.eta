<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
  <title>Book a table — <%= it.venue.name %></title>
  <style>
    :root {
      --w-accent: <%= it.accent %>;
      --w-bg:     <%= it.theme === 'dark' ? '#1a1a1a' : '#ffffff' %>;
      --w-fg:     <%= it.theme === 'dark' ? '#f5f5f5' : '#0f172a' %>;
      --w-muted:  <%= it.theme === 'dark' ? '#a3a3a3' : '#64748b' %>;
      --w-surface:<%= it.theme === 'dark' ? '#262626' : '#f8fafc' %>;
      --w-border: <%= it.theme === 'dark' ? '#2e2e2e' : '#e2e8f0' %>;
      --w-radius: 8px;
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0; padding: 0; min-height: 100%;
      background: var(--w-bg); color: var(--w-fg);
      font-family: <%= it.font_family %>, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px; line-height: 1.5;
    }
    .wrap { max-width: 520px; margin: 0 auto; padding: 24px; }
    .card { background: var(--w-bg); border: 1px solid var(--w-border); border-radius: 12px; padding: 24px; }
    h1 { margin: 0 0 4px; font-size: 22px; font-weight: 700; }
    .sub { color: var(--w-muted); font-size: 14px; margin: 0 0 20px; }
    .step-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--w-muted); font-weight: 600; margin: 0 0 8px; }
    .row { display: flex; gap: 8px; flex-wrap: wrap; }
    .pill {
      flex: 1 1 calc(25% - 8px); min-width: 64px;
      padding: 12px; border: 1px solid var(--w-border); border-radius: var(--w-radius);
      background: var(--w-bg); color: var(--w-fg);
      font-size: 15px; font-weight: 600; cursor: pointer;
      text-align: center;
    }
    .pill:hover { border-color: var(--w-accent); }
    .pill.active { background: var(--w-accent); color: #fff; border-color: var(--w-accent); }
    .pill[disabled] { opacity: 0.4; cursor: not-allowed; }
    input[type="date"], input[type="text"], input[type="email"], input[type="tel"], textarea {
      width: 100%; padding: 12px; border: 1px solid var(--w-border); border-radius: var(--w-radius);
      background: var(--w-bg); color: var(--w-fg); font-size: 16px;
      font-family: inherit;
    }
    input:focus, textarea:focus { outline: none; border-color: var(--w-accent); }
    textarea { min-height: 80px; resize: vertical; }
    label { display: block; font-size: 13px; color: var(--w-muted); margin: 0 0 6px; font-weight: 500; }
    .field { margin-bottom: 14px; }
    .btn {
      width: 100%; padding: 14px; background: var(--w-accent); color: #fff;
      border: 0; border-radius: var(--w-radius); font-size: 16px; font-weight: 600;
      cursor: pointer; font-family: inherit;
    }
    .btn:hover { filter: brightness(1.05); }
    .btn[disabled] { opacity: 0.5; cursor: not-allowed; }
    .btn.secondary { background: transparent; color: var(--w-fg); border: 1px solid var(--w-border); }
    .nav { display: flex; gap: 8px; margin-top: 18px; }
    .nav .btn { flex: 1; }
    .err { color: #dc2626; font-size: 13px; margin-top: 8px; }
    .ok { color: #16a34a; font-size: 14px; }
    .progress { display: flex; gap: 4px; margin-bottom: 20px; }
    .progress > div { flex: 1; height: 3px; border-radius: 99px; background: var(--w-border); }
    .progress > div.done { background: var(--w-accent); }
    .summary { background: var(--w-surface); border-radius: var(--w-radius); padding: 14px 16px; font-size: 14px; }
    .summary .row-line { display: flex; justify-content: space-between; padding: 4px 0; }
    .summary .row-line .lbl { color: var(--w-muted); }
    .timer { text-align: center; font-size: 13px; color: var(--w-muted); margin-top: 12px; }
    .slots { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; max-height: 300px; overflow-y: auto; padding: 2px; }
    .slot { padding: 10px; text-align: center; border: 1px solid var(--w-border); border-radius: var(--w-radius); cursor: pointer; font-size: 14px; background: var(--w-bg); color: var(--w-fg); }
    .slot:hover { border-color: var(--w-accent); }
    .slot.active { background: var(--w-accent); color: #fff; border-color: var(--w-accent); }
    .slot[disabled] { opacity: 0.3; cursor: not-allowed; text-decoration: line-through; }
    .empty { color: var(--w-muted); font-size: 14px; text-align: center; padding: 20px; }
    .loader { display: inline-block; width: 18px; height: 18px; border: 2px solid var(--w-border); border-top-color: var(--w-accent); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .center { text-align: center; }
    .check { display: inline-block; width: 48px; height: 48px; line-height: 48px; border-radius: 50%; background: #16a34a; color: #fff; font-size: 28px; margin-bottom: 12px; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1><%= it.venue.site_name || it.venue.name %></h1>
      <p class="sub">Book a table</p>
      <div class="progress" id="progress"></div>
      <div id="root"></div>
    </div>
  </div>

  <script>
    (function() {
      const VENUE_ID = <%~ JSON.stringify(it.venue.id) %>;
      const API     = <%~ JSON.stringify(it.apiBase) %>;
      const VENUE   = <%~ JSON.stringify(it.venue) %>;

      const state = {
        step: 1,                 // 1..5
        covers: 2,
        date: today(),
        slot: null,              // { slot_time, table_id, combination_id }
        details: { name: '', email: '', phone: '', notes: '' },
        hold: null,              // { id, expires_at }
        booking: null,           // confirmed result
        error: null,
        loading: false,
      };

      function today() {
        const d = new Date();
        return d.toISOString().slice(0, 10);
      }

      function maxDate() {
        const d = new Date();
        d.setDate(d.getDate() + (VENUE.booking_window_days || 30));
        return d.toISOString().slice(0, 10);
      }

      // ── API helpers ───────────────────────────────────
      async function apiFetch(path, opts = {}) {
        const res = await fetch(API + path, {
          ...opts,
          headers: { 'Content-Type': 'application/json', ...(opts.headers || {}) },
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
        return data;
      }

      // ── Navigation helpers ────────────────────────────
      function goto(step) {
        state.step = step;
        state.error = null;
        render();
      }

      async function withLoading(fn) {
        state.loading = true; state.error = null; render();
        try { await fn(); }
        catch (e) { state.error = e.message; }
        finally { state.loading = false; render(); }
      }

      // ── Step actions ──────────────────────────────────
      function pickCovers(n) { state.covers = n; goto(2); }
      function pickDate(d) { state.date = d; loadSlots(); }
      function pickSlot(slot) { state.slot = slot; goto(4); }

      async function loadSlots() {
        await withLoading(async () => {
          state.slots = await apiFetch('/venues/' + VENUE_ID + '/slots?date=' + state.date + '&covers=' + state.covers);
          state.step = 3;
        });
      }

      async function createHold() {
        await withLoading(async () => {
          // The slot's `slot_time` is HH:MM; build full ISO with venue date.
          const startsAt = new Date(state.date + 'T' + state.slot.slot_time + ':00').toISOString();
          state.hold = await apiFetch('/venues/' + VENUE_ID + '/holds', {
            method: 'POST',
            body: JSON.stringify({
              starts_at:      startsAt,
              covers:         state.covers,
              table_id:       state.slot.table_id || null,
              combination_id: state.slot.combination_id || null,
              guest_name:     state.details.name || 'Guest',
              guest_email:    state.details.email || null,
              guest_phone:    state.details.phone || null,
            }),
          });
          state.step = 4;
        });
      }

      async function confirmBooking() {
        await withLoading(async () => {
          state.booking = await apiFetch('/venues/' + VENUE_ID + '/holds/' + state.hold.id + '/confirm', {
            method: 'POST',
            body: JSON.stringify({
              guest_name:  state.details.name,
              guest_email: state.details.email || null,
              guest_phone: state.details.phone || null,
              guest_notes: state.details.notes || null,
            }),
          });
          state.step = 5;
          // Notify parent for analytics / redirect
          try { window.parent.postMessage({ type: 'macaroonie:booking-confirmed', booking: state.booking }, '*'); } catch (e) {}
        });
      }

      function cancelHold() {
        if (state.hold) {
          fetch(API + '/venues/' + VENUE_ID + '/holds/' + state.hold.id, { method: 'DELETE' }).catch(() => {});
        }
        state.hold = null;
      }

      // Cancel hold on unload
      window.addEventListener('beforeunload', cancelHold);

      // ── Rendering ────────────────────────────────────
      function el(tag, attrs = {}, ...children) {
        const node = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (k === 'class') node.className = v;
          else if (k === 'onclick' || k === 'oninput' || k === 'onchange') node[k] = v;
          else if (k === 'disabled' && v) node.setAttribute('disabled', 'disabled');
          else if (v != null) node.setAttribute(k, v);
        }
        for (const c of children.flat()) {
          if (c == null || c === false) continue;
          node.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
        }
        return node;
      }

      function progress() {
        const bar = document.getElementById('progress');
        bar.innerHTML = '';
        for (let i = 1; i <= 5; i++) {
          const d = document.createElement('div');
          if (i < state.step) d.className = 'done';
          if (i === state.step) d.className = 'done';
          bar.appendChild(d);
        }
      }

      function render() {
        progress();
        const root = document.getElementById('root');
        root.innerHTML = '';

        if (state.loading) {
          root.appendChild(el('div', { class: 'center' }, el('div', { class: 'loader' })));
          return;
        }

        if (state.step === 1) renderCovers(root);
        else if (state.step === 2) renderDate(root);
        else if (state.step === 3) renderSlots(root);
        else if (state.step === 4) renderDetails(root);
        else if (state.step === 5) renderConfirmed(root);

        if (state.error) {
          root.appendChild(el('div', { class: 'err' }, state.error));
        }
      }

      function renderCovers(root) {
        root.appendChild(el('p', { class: 'step-label' }, 'How many guests?'));
        const max = Math.min(VENUE.max_covers || 8, 12);
        const min = VENUE.min_covers || 1;
        const pills = el('div', { class: 'row' });
        for (let n = min; n <= max; n++) {
          const p = el('button', {
            class: 'pill' + (state.covers === n ? ' active' : ''),
            onclick: () => pickCovers(n),
          }, String(n));
          pills.appendChild(p);
        }
        root.appendChild(pills);
        root.appendChild(el('p', { class: 'sub', style: 'margin-top:14px' },
          'Larger party? Call us — we\'ll arrange combined tables.'));
      }

      function renderDate(root) {
        root.appendChild(el('p', { class: 'step-label' }, 'Pick a date'));
        const inp = el('input', {
          type: 'date',
          value: state.date,
          min: today(),
          max: maxDate(),
          onchange: (e) => pickDate(e.target.value),
        });
        root.appendChild(el('div', { class: 'field' }, inp));
        const nav = el('div', { class: 'nav' },
          el('button', { class: 'btn secondary', onclick: () => goto(1) }, '← Back'),
          el('button', { class: 'btn', onclick: () => loadSlots() }, 'Find times'),
        );
        root.appendChild(nav);
      }

      function renderSlots(root) {
        root.appendChild(el('p', { class: 'step-label' }, 'Pick a time'));
        const slots = state.slots || [];
        const available = slots.filter(s => s.reason !== 'unavailable' && s.reason !== 'full' && s.available_seats >= state.covers);

        if (available.length === 0) {
          root.appendChild(el('p', { class: 'empty' },
            'No times available on this date for ' + state.covers + ' guest' + (state.covers > 1 ? 's' : '') + '. Try another day.'));
        } else {
          const grid = el('div', { class: 'slots' });
          available.forEach(s => {
            const sl = el('button', {
              class: 'slot' + (state.slot?.slot_time === s.slot_time ? ' active' : ''),
              onclick: () => pickSlot(s),
            }, s.slot_time);
            grid.appendChild(sl);
          });
          root.appendChild(grid);
        }

        const nav = el('div', { class: 'nav' },
          el('button', { class: 'btn secondary', onclick: () => goto(2) }, '← Date'),
        );
        root.appendChild(nav);
      }

      function renderDetails(root) {
        root.appendChild(el('div', { class: 'summary' },
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'Date'), el('span', {}, formatDate(state.date))),
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'Time'), el('span', {}, state.slot.slot_time)),
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'Guests'), el('span', {}, String(state.covers))),
        ));

        const setField = (k) => (e) => { state.details[k] = e.target.value; };
        const form = el('div', { style: 'margin-top:16px' });
        form.appendChild(el('div', { class: 'field' },
          el('label', {}, 'Name *'),
          el('input', { type: 'text', value: state.details.name, oninput: setField('name'), placeholder: 'Your name' }),
        ));
        form.appendChild(el('div', { class: 'field' },
          el('label', {}, 'Email'),
          el('input', { type: 'email', value: state.details.email, oninput: setField('email'), placeholder: 'you@example.com', inputmode: 'email' }),
        ));
        form.appendChild(el('div', { class: 'field' },
          el('label', {}, 'Phone'),
          el('input', { type: 'tel', value: state.details.phone, oninput: setField('phone'), placeholder: '+44 7700 900000', inputmode: 'tel' }),
        ));
        form.appendChild(el('div', { class: 'field' },
          el('label', {}, 'Notes (optional)'),
          el('textarea', { oninput: setField('notes'), placeholder: 'Allergies, special occasions…' }, state.details.notes),
        ));
        root.appendChild(form);

        const valid = (state.details.name || '').trim().length >= 2;
        const nav = el('div', { class: 'nav' },
          el('button', { class: 'btn secondary', onclick: () => goto(3) }, '← Time'),
          el('button', {
            class: 'btn',
            disabled: !valid,
            onclick: async () => {
              if (!state.hold) await createHold();
              if (state.hold) await confirmBooking();
            },
          }, 'Confirm booking'),
        );
        root.appendChild(nav);
      }

      function renderConfirmed(root) {
        const b = state.booking || {};
        root.appendChild(el('div', { class: 'center' },
          el('span', { class: 'check' }, '✓'),
        ));
        root.appendChild(el('h2', { class: 'center', style: 'margin:0 0 6px;font-size:20px;' }, 'You\'re booked'));
        root.appendChild(el('p', { class: 'sub center' },
          'Reference: ' + (b.reference || '—'),
        ));
        root.appendChild(el('div', { class: 'summary', style: 'margin-top:16px' },
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'Name'),  el('span', {}, b.guest_name || '—')),
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'When'),  el('span', {}, formatDate(state.date) + ' at ' + state.slot.slot_time)),
          el('div', { class: 'row-line' }, el('span', { class: 'lbl' }, 'Guests'), el('span', {}, String(state.covers))),
        ));
        if (b.guest_email) {
          root.appendChild(el('p', { class: 'sub center', style: 'margin-top:14px;' },
            'Confirmation sent to ' + b.guest_email + '.'));
        }
      }

      function formatDate(iso) {
        try {
          return new Date(iso + 'T12:00:00').toLocaleDateString(undefined, { weekday: 'short', day: 'numeric', month: 'short' });
        } catch (e) { return iso; }
      }

      // Initial render
      render();
    })();
  </script>
</body>
</html>
