<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.pageTitle || it.config.meta_title || it.config.site_name || it.tenant_name %></title>
  <% if (it.config.meta_description) { %>
    <meta name="description" content="<%= it.config.meta_description %>" />
  <% } %>
  <% if (it.config.favicon_url) { %>
    <link rel="icon" href="<%= it.config.favicon_url %>" />
  <% } %>

  <!-- Open Graph -->
  <meta property="og:title" content="<%= it.config.meta_title || it.config.site_name || it.tenant_name %>" />
  <meta property="og:type"  content="website" />
  <meta property="og:url"   content="<%= it.siteUrl %>" />
  <% if (it.config.og_image_url) { %>
    <meta property="og:image" content="<%= it.config.og_image_url %>" />
  <% } %>
  <% if (it.config.meta_description) { %>
    <meta property="og:description" content="<%= it.config.meta_description %>" />
  <% } %>
  <meta name="twitter:card" content="summary_large_image" />

  <!-- JSON-LD Restaurant schema -->
  <script type="application/ld+json">
    <%~ JSON.stringify({
      "@context": "https://schema.org",
      "@type":    "Restaurant",
      "name":     it.config.site_name || it.tenant_name,
      "url":      it.siteUrl,
      "telephone": it.config.phone || undefined,
      "email":     it.config.email || undefined,
      "address":   it.config.address_line1 ? {
        "@type":           "PostalAddress",
        "streetAddress":   [it.config.address_line1, it.config.address_line2].filter(Boolean).join(', '),
        "addressLocality": it.config.city || undefined,
        "postalCode":      it.config.postcode || undefined,
        "addressCountry":  it.config.country || 'GB',
      } : undefined,
      "geo": (it.config.latitude && it.config.longitude) ? {
        "@type":     "GeoCoordinates",
        "latitude":  it.config.latitude,
        "longitude": it.config.longitude,
      } : undefined,
      "image": it.config.hero_image_url || it.config.og_image_url || undefined,
    }) %>
  </script>

  <style>
    :root {
      --primary:   <%= it.config.primary_colour || '#630812' %>;
      --secondary: <%= it.config.secondary_colour || '#f9f6f1' %>;
      --font: <%= it.config.font_family || 'Inter' %>, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; font-family: var(--font); color: #1a1a1a; line-height: 1.5; }
    img { max-width: 100%; display: block; }
    a { color: var(--primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .btn {
      display: inline-block; padding: 12px 28px; background: var(--primary); color: white;
      border-radius: 4px; font-weight: 600; text-decoration: none; font-size: 15px;
      border: none; cursor: pointer; transition: opacity .2s;
    }
    .btn:hover { opacity: 0.9; text-decoration: none; }
    .btn-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
    .site-header {
      position: sticky; top: 0; background: #fff; z-index: 20;
      border-bottom: 1px solid #e5e7eb; padding: 14px 0;
    }
    .site-header .container { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
    .site-header .brand { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 18px; color: #1a1a1a; }
    .site-header .brand img { height: 36px; width: auto; }
    .site-header nav { display: flex; gap: 24px; align-items: center; }
    .site-header nav a { color: #333; font-size: 14px; font-weight: 500; }
    .site-header nav a.cta { color: white; background: var(--primary); padding: 8px 18px; border-radius: 4px; }
    .site-header nav a.cta:hover { text-decoration: none; opacity: 0.9; }
    section.block { padding: 72px 0; }
    section.block h2 { font-size: 32px; margin: 0 0 24px; color: var(--primary); font-weight: 700; }
    .site-footer {
      background: #1a1a1a; color: #cfcfcf; padding: 48px 0 32px; margin-top: 0; font-size: 14px;
    }
    .site-footer a { color: #fff; }
    .site-footer .cols { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 32px; }
    @media (max-width: 700px) {
      .site-header nav { gap: 12px; }
      .site-header nav a:not(.cta) { display: none; }
      section.block { padding: 48px 0; }
      section.block h2 { font-size: 26px; }
      .site-footer .cols { grid-template-columns: 1fr; }
    }
  </style>

  <% if (it.config.ga4_measurement_id) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= it.config.ga4_measurement_id %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= it.config.ga4_measurement_id %>');
    </script>
  <% } %>

  <% if (it.config.fb_pixel_id) { %>
    <script>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '<%= it.config.fb_pixel_id %>');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=<%= it.config.fb_pixel_id %>&ev=PageView&noscript=1" /></noscript>
  <% } %>
</head>
<body>
