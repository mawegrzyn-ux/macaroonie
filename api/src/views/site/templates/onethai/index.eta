<%~ include('../../shared/head', it) %>
<%~ include('./partials/header', it) %>
<main>
<%
const blocks = Array.isArray(it.config.home_blocks) ? it.config.home_blocks : []
%>
<% if (blocks.length === 0) { %>
  <%~ include('./fallback_home', it) %>
<% } else { %>
  <% for (const block of blocks) { %>
    <%~ include('../../blocks/renderer', { ...it, block }) %>
  <% } %>
<% } %>
</main>
<%~ include('./partials/footer', it) %>
