# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/macaroonie_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth0 ─────────────────────────────────────────────────────
# Domain from your Auth0 tenant (no https://)
AUTH0_DOMAIN=macaroonie.eu.auth0.com
# API identifier from Auth0 → Applications → APIs
AUTH0_AUDIENCE=https://api.macaroonie.com

# ── Auth0 Management API (for in-app team + tenant provisioning) ─
# Create a Machine-to-Machine app in Auth0 → Applications → APIs →
# Auth0 Management API → "Machine to Machine Applications" tab.
# Authorise scopes:
#
#   Team invites / management:
#     read:users, update:users, read:organization_invitations,
#     create:organization_invitations, read:organization_members,
#     delete:organization_member_roles, delete:organization_members
#
#   Auto-provisioning new tenants from /platform (optional but recommended):
#     create:organizations, update:organizations, read:organizations,
#     read:connections, create:organization_connections,
#     update:organization_connections
#
# Leave these blank in dev to disable both features (Team page invites
# locally only; tenant creation requires manual Auth0 org id paste).
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
# SPA client_id users land in after accepting an invitation.
# Same value as VITE_AUTH0_CLIENT_ID in admin/.env.
AUTH0_INVITE_CLIENT_ID=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email ─────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@macaroonie.com

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
