# =============================================================
# .gitignore — Booking Platform
# Covers: api/, admin/, migrations/, deploy scripts
# =============================================================

# ── Environment & secrets ─────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.db_credentials

# ── Node ──────────────────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*

# ── Build output ──────────────────────────────────────────────
admin/dist/
admin/.vite/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ── PM2 ───────────────────────────────────────────────────────
.pm2/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Test & coverage ───────────────────────────────────────────
coverage/
.vitest/
test-results/

# ── Misc ──────────────────────────────────────────────────────
*.pem
*.key
backups/
releases/
